---
import Layout from "@/layouts/Layout.astro";

const projects = [
  {
    name: "The-Site",
    description:
      "A fullstack web app built with SvelteKit, TypeScript, Tailwind, Prisma, and Lucia. Designed for easy dissemination of illegal government programs.",
    link: "https://github.com/gravy59/the-site",
    wip: true,
  },
  {
    name: "scp-db",
    description:
      "A curation of the best SCPs from the foundation. Built with Next.js and Contentlayer, with a 100% Chrome Lighthouse score",
    link: "https://scp-db-zeta.vercel.app/",
    wip: false,
  },
  {
    name: "WOPR Console",
    description: "A C# spoof of the WOPR from the 1983 cult classic film WarGames.",
    link: "https://github.com/gravy59/wopr-console/",
    wip: false,
  },
  {
    name: "pi-nuker.py",
    description: "Simple Nuking and Trolling for Minecraft: Pi Edition ",
    link: "https://github.com/Gravy59/pi-nuker.py/",
    wip: true,
  },
];
---

<Layout>
  <main class="flex-1 pb-16" transition:animate="slide">
    <h1 class="text-4xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100 sm:text-5xl">
      Projects
    </h1>
    <p class="mt-6 text-base text-zinc-600 dark:text-zinc-400">Creations I&rsquo;m proud of</p>
    <ul role="list" class="mt-6 grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-2">
      {
        projects.map((project) => (
          <li class="group relative flex flex-col items-start rounded-lg px-4 py-6 shadow-sm ring-1 ring-zinc-900/5 transition hover:bg-zinc-50 hover:shadow-none dark:ring-white/10 dark:hover:bg-zinc-800/50">
            <h2 class="flex w-full justify-between text-base font-semibold text-zinc-800 dark:text-zinc-100">
              <a href={project.link}>
                <span class="absolute inset-0 z-20" />
                {project.name}
              </a>
              {project.wip && (
                <span class="inline-flex items-center rounded-md bg-yellow-50 px-2 py-1 text-xs font-medium text-yellow-800 ring-1 ring-inset ring-yellow-600/20 dark:bg-yellow-400/10 dark:text-yellow-500 dark:ring-yellow-400/20">
                  WIP
                </span>
              )}
            </h2>
            <p class="relative z-10 mt-2 text-sm text-zinc-600 dark:text-zinc-400">
              {project.description}
            </p>
            <p class="relative z-10 mt-6 flex items-center gap-x-2 text-sm font-medium text-zinc-400 transition group-hover:text-orange-500 dark:text-zinc-200">
              <svg
                aria-hidden
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 256 256"
                class="h-6 w-6">
                <path
                  d="M137.54,186.36a8,8,0,0,1,0,11.31l-9.94,10A56,56,0,0,1,48.38,128.4L72.5,104.28A56,56,0,0,1,149.31,102a8,8,0,1,1-10.64,12,40,40,0,0,0-54.85,1.63L59.7,139.72a40,40,0,0,0,56.58,56.58l9.94-9.94A8,8,0,0,1,137.54,186.36Zm70.08-138a56.08,56.08,0,0,0-79.22,0l-9.94,9.95a8,8,0,0,0,11.32,11.31l9.94-9.94a40,40,0,0,1,56.58,56.58L172.18,140.4A40,40,0,0,1,117.33,142,8,8,0,1,0,106.69,154a56,56,0,0,0,76.81-2.26l24.12-24.12A56.08,56.08,0,0,0,207.62,48.38Z"
                  fill="currentColor"
                />
              </svg>
              <span>{new URL(project.link).hostname}</span>
            </p>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
