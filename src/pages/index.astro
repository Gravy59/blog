---
import QuoteOfTheDay from "@/components/QuoteOfTheDay.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <main class="flex-1 pb-16" transition:animate="slide">
    <h1
      class="text-4xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100 sm:text-5xl">
      &#x1F44B;&#x1F3FB; Hey there.
    </h1>
    <p class="text-lg mt-6 text-zinc-600 dark:text-zinc-400">
      Welcome to my humble corner of the internet. Here you can read my musings
      as a student &ldquo;tech bro&rdquo;, music enthusiast, creative writer,
      and <em>explorer of the labyrinth</em>. I like to create things that
      matter to me &mdash; including this website.
    </p>
    <QuoteOfTheDay />
  </main>
</Layout>
