---
import QuoteOfTheDay from "@/components/QuoteOfTheDay.astro";
import Layout from "@/layouts/Layout.astro";
import ArrowRight from "phosphor-astro/ArrowRight.astro";
---

<Layout>
  <main class="flex-1 pb-16">
    <h1
      class="text-4xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100 sm:text-5xl">
      &#x1F44B;&#x1F3FB; Hey there.
    </h1>
    <p class="text-lg mt-6 text-zinc-600 dark:text-zinc-400">
      Welcome to my humble corner of the internet. Here you can read my musings
      as a student &ldquo;tech bro&rdquo;, music enthusiast, creative writer,
      and <em>explorer of the labyrinth</em>. I like to create things that
      matter to me &mdash; including this website.
    </p>
    <QuoteOfTheDay />
    <section class="mb-16">
      <h1
        class="text-3xl mb-8 font-bold tracking-tight text-zinc-800 dark:text-zinc-100 sm:text-3xl">
        Featured
      </h1>
      <div class="flex flex-col gap-8">
        <article
          class="rounded-2xl relative ring-1 shadow-sm ring-zinc-200 dark:ring-zinc-500 p-4 sm:p-8 flex flex-col items-start transition hover:bg-zinc-100">
          <h2
            class="text-base font-medium tracking-tight text-zinc-800 dark:text-zinc-100"
            <>
            <a
              href="/articles/crafting-a-design-system-for-a-multiplanetary-future">
              <span class="absolute inset-0"></span>
              <span class="relative z-10">Lorem Ipsum Delor Sit</span>
            </a>
          </h2>
          <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
            Lorem, ipsum dolor sit amet consectetur adipisicing elit.
            Temporibus, repellat quos! Optio, quas porro neque saepe illum
            sapiente nam nesciunt. Soluta, doloremque. Labore, sit. Laborum
            optio earum nam rem minus?
          </p>
          <div
            class="mt-4 text-sm font-medium text-orange-500 flex items-center"
            aria-hidden>
            Read post <ArrowRight class="ml-1 h-4 w-4 stroke-current" />
          </div>
        </article>
        <article
          class="rounded-2xl relative ring-1 shadow-sm ring-zinc-200 dark:ring-zinc-500 p-4 sm:p-8 flex flex-col items-start transition hover:bg-zinc-100">
