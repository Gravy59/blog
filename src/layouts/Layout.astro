---
import { ViewTransitions } from "astro:transitions";
import "@fontsource-variable/inter";
import "@/styles/globals.css";
import BaseHead from "@/components/BaseHead.astro";
import SEOTags from "@/components/SEOTags.astro";
import TwitterLogo from "phosphor-astro/TwitterLogo.astro";
import GithubLogo from "phosphor-astro/GithubLogo.astro";
import Envelope from "phosphor-astro/Envelope.astro";
import Moon from "phosphor-astro/Moon.astro";
import Sun from "phosphor-astro/Sun.astro";

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full scroll-smooth antialiased">
  <head>
    <BaseHead title={title} description={description} />
    <SEOTags />
    <script is:inline src="/toggle-theme.js"></script>
    <ViewTransitions />
  </head>
  <body
    class="flex min-h-full flex-col bg-white font-sans text-zinc-900 dark:bg-zinc-900 dark:text-zinc-50">
    <header class="py-6">
      <nav class="container flex flex-col items-center justify-between sm:flex-row">
        <a href="/" aria-label="Home" class="text-2xl text-zinc-800 dark:text-zinc-200">
          <span aria-hidden>Gravy59</span>
        </a>
        <div
          class="flex items-center gap-x-1 text-sm/6 font-medium text-zinc-800 dark:text-zinc-200">
          <a
            href="/about"
            class="inline-flex h-full max-w-3xl items-center px-3 py-2 transition hover:text-orange-400">
            About
          </a>
          <a
            href="/projects"
            class="inline-flex h-full max-w-3xl items-center px-3 py-2 transition hover:text-orange-400">
            Projects
          </a>
          <a
            href="/writing"
            class="inline-flex h-full max-w-3xl items-center px-3 py-2 transition hover:text-orange-400">
            Writing
          </a>

          <button
            id="theme-btn"
            aria-label="auto"
            aria-live="polite"
            title="Toggles light & dark mode"
            class="inline-flex h-full max-w-3xl items-center px-3 py-2 transition hover:text-orange-400">
            <Moon aria-hidden class="h-6 w-6 dark:hidden" />
            <Sun aria-hidden class="hidden h-6 w-6 dark:block [&>line]:stroke-current" />
          </button>
        </div>
      </nav>
    </header>
    <slot />
    <footer
      class="container flex flex-col items-center justify-between gap-y-3 border-t border-zinc-200 py-8 dark:border-zinc-500 sm:flex-row">
      <div
        class="flex flex-wrap gap-x-6 gap-y-1 text-sm font-medium text-zinc-800 dark:text-zinc-200">
        <a
          class="transition hover:text-orange-500 dark:hover:text-orange-400"
          href="https://x.com/gravy59_">
          <TwitterLogo aria-hidden class="h-4 w-4" />
          <span class="sr-only">Gravy59 on Twitter</span>
        </a>
        <a
          class="transition hover:text-orange-500 dark:hover:text-orange-400"
          href="https://github.com/gravy59">
          <GithubLogo aria-hidden class="h-4 w-4 [&>path]:stroke-current" />
          <span class="sr-only">Gravy59 on GitHub</span>
        </a>
        <a
          class="transition hover:text-orange-500 dark:hover:text-orange-400"
          href="mailto:gravy59@proton.me">
          <Envelope aria-hidden class="h-4 w-4 [&>:not(rect)]:stroke-current" />
          <span class="sr-only">Email Gravy59</span>
        </a>
        <a
          class="transition hover:text-orange-500 dark:hover:text-orange-400"
          href="https://steamcommunity.com/id/gravy59">
          <svg
            aria-hidden
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="currentColor"
            viewBox="0 0 496 512">
            <path
              d="M496 256c0 137-111.2 248-248.4 248-113.8 0-209.6-76.3-239-180.4l95.2 39.3c6.4 32.1 34.9 56.4 68.9 56.4 39.2 0 71.9-32.4 70.2-73.5l84.5-60.2c52.1 1.3 95.8-40.9 95.8-93.5 0-51.6-42-93.5-93.7-93.5s-93.7 42-93.7 93.5v1.2L176.6 279c-15.5-.9-30.7 3.4-43.5 12.1L0 236.1C10.2 108.4 117.1 8 247.6 8 384.8 8 496 119 496 256zM155.7 384.3l-30.5-12.6a52.79 52.79 0 0 0 27.2 25.8c26.9 11.2 57.8-1.6 69-28.4 5.4-13 5.5-27.3.1-40.3-5.4-13-15.5-23.2-28.5-28.6-12.9-5.4-26.7-5.2-38.9-.6l31.5 13c19.8 8.2 29.2 30.9 20.9 50.7-8.3 19.9-31 29.2-50.8 21zm173.8-129.9c-34.4 0-62.4-28-62.4-62.3s28-62.3 62.4-62.3 62.4 28 62.4 62.3-27.9 62.3-62.4 62.3zm.1-15.6c25.9 0 46.9-21 46.9-46.8 0-25.9-21-46.8-46.9-46.8s-46.9 21-46.9 46.8c.1 25.8 21.1 46.8 46.9 46.8z"
            ></path>
          </svg>
          <span class="sr-only">Gravy59 on Steam</span>
        </a>
      </div>
      <p class="text-right text-sm text-zinc-500">
        Copyright &copy; {new Date().getFullYear()} Gravy59.
      </p>
    </footer>
  </body>
</html>
