---
type Props = {
  title: string;
  description: string;
  pubDate?: Date;
  heroImage?: string;
  caption?: string;
};

const { title, description, pubDate, heroImage, caption } = Astro.props;
import "@fontsource-variable/inter";
import Layout from "./Layout.astro";
---

<Layout {title} {description}>
  <main class="pb-16 flex-1">
    <article>
      {
        heroImage && (
          <figure
            class="mb-6"
            transition:animate="slide"
            transition:name="heroImage">
            <img
              width={1020}
              height={510}
              src={heroImage}
              alt=""
              class="rounded-2xl mb-2"
            />
            {caption && (
              <figcaption class="text-xs text-zinc-500 dark:text-zinc-400">
                {caption}
              </figcaption>
            )}
          </figure>
        )
      }
      <header class="flex flex-col" transition:name="blogPostHeader">
        <h1
          transition:animate="slide"
          transition:name="blogPostTitle"
          class="mt-6 text-4xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100 sm:text-5xl">
          {title}
        </h1>{
          pubDate && (
            <time
              transition:animate="slide"
              transition:name="pubDate"
              datetime={pubDate.toISOString().split("T")[0]}
              class="order-first flex items-center text-base text-zinc-400 dark:text-zinc-500">
              {pubDate.toLocaleDateString("en-us", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </time>
          )
        }
      </header>
      <div class="prose dark:prose-invert mt-8" transition:name="blogPostBody">
        <slot />
      </div>
    </article>
  </main>
</Layout>
